{
  "name": "boilerplate",
  "version": "1.0.0",
  "description": "Express API Boilerplate",
  "type": "module",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand --colors --config jest.config.cjs",
    "dev": "tsx watch src/main.ts",
    "start": "node --import tsx/esm dist/main.js",
    "build": "tsc",
    "type:check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/db/migrate.ts",
    "db:migrate:prod": "node dist/infrastructure/db/migrate.js",
    "db:studio": "drizzle-kit studio",
    "events:worker:dev": "tsx src/infrastructure/queue/eventsWorker.ts",
    "events:worker:prod": "node dist/infrastructure/queue/eventsWorker.js",
    "workers:dev": "npm-run-all --parallel events:worker:dev",
    "workers:prod": "npm-run-all --parallel events:worker:prod"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^6.10.1",
    "@bull-board/express": "^6.10.1",
    "@prelude.so/sdk": "^0.5.0",
    "@scalar/express-api-reference": "^0.8.28",
    "@types/express-rate-limit": "^5.1.3",
    "@types/morgan": "^1.9.10",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.4.7",
    "bullmq": "^5.56.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "class-validator-jsonschema": "^5.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.41.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.4.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "marked": "^15.0.12",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "pg": "^8.16.0",
    "redis": "^5.5.6",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.2",
    "routing-controllers-openapi": "^5.0.0",
    "tsconfig-paths": "^4.2.0",
    "typedi": "^0.10.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.1.0",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.4"
  }
}